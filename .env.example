# FastAPI
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRES_MINUTES=1440

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_research
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Firecrawl
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxx
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# OpenAI-compatible LLM endpoint (e.g., OpenRouter)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=liquid/lfm-2.5-1.2b-thinking:free
LLM_API_KEY=

# Storage
PDF_OUTPUT_DIR=./storage/pdfs

# Queue
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=crawl
USE_QUEUE=true

# SMTP (Forgot Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
PASSWORD_RESET_CODE_EXPIRY_MINUTES=10

# Strapi (headless CMS)
STRAPI_DB_NAME=ai_research_cms
STRAPI_DB_USER=${POSTGRES_USER}
STRAPI_DB_PASSWORD=${POSTGRES_PASSWORD}
STRAPI_APP_KEYS=changeme1,changeme2,changeme3,changeme4
STRAPI_API_TOKEN_SALT=changeme-api-token-salt
STRAPI_ADMIN_JWT_SECRET=changeme-admin-jwt
STRAPI_JWT_SECRET=changeme-jwt
